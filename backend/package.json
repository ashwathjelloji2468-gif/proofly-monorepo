{
  "name": "testimonials-backend",
  "version": "1.0.0",
  "description": "GraphQL backend clone of Testimonials.to with Apollo Server, Prisma, and PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc && mkdir -p dist/schema && cp src/schema/*.graphql dist/schema/",
    "postinstall": "prisma generate && tsc && mkdir -p dist/schema && cp src/schema/*.graphql dist/schema/",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src -e ts,graphql --exec ts-node src/index.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "graphql",
    "apollo",
    "prisma",
    "postgresql",
    "testimonials"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^4.10.4",
    "@prisma/client": "^5.15.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.8.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.15.0",
    "stripe": "^22.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
