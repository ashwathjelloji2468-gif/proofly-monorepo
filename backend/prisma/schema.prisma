datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BillingTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum TestimonialType {
  TEXT
  VIDEO
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ImportedFrom {
  TWITTER
  GOOGLE
  PRODUCTHUNT
}

enum SpaceRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String
  name                 String
  tier                 BillingTier           @default(FREE)
  aiCreditsUsed        Int                   @default(0)
  isVerified           Boolean               @default(false)
  status               String                @default("ACTIVE") // ACTIVE, DISABLED
  provider             String                @default("EMAIL") // EMAIL, GOOGLE, GITHUB
  hasPassword          Boolean               @default(true)
  failedLoginAttempts  Int                   @default(0)
  lockoutUntil         DateTime?
  lastLogin            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  spaces               Space[]
  memberships          SpaceMember[]
  invitations          WorkspaceInvitation[] @relation("invitedBy")
  passwordResetTokens  PasswordResetToken[]
  otpTokens            OTPToken[]
  emailChangeRequest   EmailChangeRequest?
  sessions             Session[]
  refreshTokens        RefreshToken[]
  oauthAccounts        OAuthAccount[]
  loginHistories       LoginHistory[]
  auditLogs            AuditLog[]
  passwordHistories    PasswordHistory[]
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Space {
  id               String                @id @default(uuid())
  name             String
  slug             String                @unique
  headerTitle      String
  customMessage    String
  logoUrl          String?
  collectVideo     Boolean               @default(true)
  collectText      Boolean               @default(true)
  theme            String                @default("light")
  showBranding     Boolean               @default(true)
  customDomain     String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  testimonials     Testimonial[]
  campaigns        Campaign[]
  webhooks         Webhook[]
  reward           Reward?
  members          SpaceMember[]
  invitations      WorkspaceInvitation[]
}

model SpaceMember {
  id        String    @id @default(uuid())
  spaceId   String
  userId    String
  role      SpaceRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
}

model WorkspaceInvitation {
  id         String    @id @default(uuid())
  spaceId    String
  email      String
  role       SpaceRole @default(MEMBER)
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  space      Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  inviter    User      @relation("invitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([spaceId, email])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTPToken {
  id        String   @id @default(uuid())
  userId    String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailChangeRequest {
  id          String   @id @default(uuid())
  userId      String   @unique
  oldEmail    String
  newEmail    String
  oldToken    String   @unique
  newToken    String   @unique
  oldVerified Boolean  @default(false)
  newVerified Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent    String?
  ipAddress    String?
  deviceType   String?        @default("Desktop")
  isValid      Boolean        @default(true)
  createdAt    DateTime       @default(now())
  expiresAt    DateTime
  lastActivity DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

model OAuthAccount {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String   // "GOOGLE", "GITHUB"
  providerUserId String   // unique identifier from google/github
  metadata       Json?
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  status     String   // "SUCCESS", "FAIL_PASSWORD", "FAIL_LOCKED", etc.
  createdAt  DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id             String          @id @default(uuid())
  type           TestimonialType
  textContent    String?
  videoUrl       String?
  rating         Int             @default(5)
  reviewerName   String
  reviewerEmail  String
  reviewerTitle  String?
  reviewerSocial String?
  reviewerAvatar String?
  isApproved     Boolean         @default(false)
  isArchived     Boolean         @default(false)
  isPinned       Boolean         @default(false)
  sentiment      Sentiment?
  importedFrom   ImportedFrom?
  externalLink   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  spaceId        String
  space          Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Reward {
  id           String   @id @default(uuid())
  discountCode String
  message      String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  spaceId      String   @unique
  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Campaign {
  id         String   @id @default(uuid())
  subject    String
  emailBody  String
  recipients String[]
  sentCount  Int      @default(0)
  spaceId    String
  space      Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Webhook {
  id        String   @id @default(uuid())
  url       String
  isActive  Boolean  @default(true)
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  spaceId   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model StaticPage {
  slug      String   @id
  title     String
  content   String
  updatedAt DateTime @updatedAt
}
