datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BillingTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum TestimonialType {
  TEXT
  VIDEO
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ImportedFrom {
  TWITTER
  GOOGLE
  PRODUCTHUNT
}

enum SpaceRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String
  name                 String
  tier                 BillingTier           @default(FREE)
  aiCreditsUsed        Int                   @default(0)
  isVerified           Boolean               @default(false)
  status               String                @default("ACTIVE") // ACTIVE, DISABLED
  provider             String                @default("EMAIL") // EMAIL, GOOGLE, GITHUB
  hasPassword          Boolean               @default(true)
  failedLoginAttempts  Int                   @default(0)
  lockoutUntil         DateTime?
  lastLogin            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  spaces               Space[]
  memberships          SpaceMember[]
  invitations          WorkspaceInvitation[] @relation("invitedBy")
  passwordResetTokens  PasswordResetToken[]
  otpTokens            OTPToken[]
  emailChangeRequest   EmailChangeRequest?
  sessions             Session[]
  refreshTokens        RefreshToken[]
  oauthAccounts        OAuthAccount[]
  loginHistories       LoginHistory[]
  auditLogs            AuditLog[]
  passwordHistories    PasswordHistory[]
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Space {
  id               String                @id @default(uuid())
  name             String
  slug             String                @unique
  headerTitle      String
  customMessage    String
  logoUrl          String?
  collectVideo     Boolean               @default(true)
  collectText      Boolean               @default(true)
  theme            String                @default("light")
  showBranding     Boolean               @default(true)
  customDomain     String?
  domainStatus     String?               @default("PENDING") // PENDING, VERIFIED, FAILED
  whiteLabel       WhiteLabelConfig?
  smtp             SmtpConfig?
  qrScans          Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  testimonials     Testimonial[]
  campaigns        Campaign[]
  reward           Reward?
  members          SpaceMember[]
  invitations      WorkspaceInvitation[]
  widgets          Widget[]
  collections      Collection[]
  showcaseSettings ShowcaseSettings?
  showcaseViews    ShowcaseView[]
  showcaseShares   ShowcaseShare[]
  visitors         Visitor[]
  goals            Goal[]
  conversions      Conversion[]
  revenueEvents    RevenueEvent[]
  heatmapEvents    HeatmapEvent[]
  reports          Report[]
  aiUsage          AIUsage?
  aiHistory        AIHistory[]
  aiInsights       AIInsight[]
  aiJobs           AIJob[]
  apiKeys          ApiKey[]
  connections      IntegrationConnection[]
  webhooksList     WebhookSubscription[]
  apiLogs          ApiLog[]
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  inAppNotifications InAppNotification[]
}

model SpaceMember {
  id        String    @id @default(uuid())
  spaceId   String
  userId    String
  role      SpaceRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
}

model WorkspaceInvitation {
  id         String    @id @default(uuid())
  spaceId    String
  email      String
  role       SpaceRole @default(MEMBER)
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  space      Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  inviter    User      @relation("invitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([spaceId, email])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTPToken {
  id        String   @id @default(uuid())
  userId    String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailChangeRequest {
  id          String   @id @default(uuid())
  userId      String   @unique
  oldEmail    String
  newEmail    String
  oldToken    String   @unique
  newToken    String   @unique
  oldVerified Boolean  @default(false)
  newVerified Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent    String?
  ipAddress    String?
  deviceType   String?        @default("Desktop")
  isValid      Boolean        @default(true)
  createdAt    DateTime       @default(now())
  expiresAt    DateTime
  lastActivity DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

model OAuthAccount {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String   // "GOOGLE", "GITHUB"
  providerUserId String   // unique identifier from google/github
  metadata       Json?
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  status     String   // "SUCCESS", "FAIL_PASSWORD", "FAIL_LOCKED", etc.
  createdAt  DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id             String          @id @default(uuid())
  type           TestimonialType
  textContent    String?
  videoUrl       String?
  rating         Int             @default(5)
  reviewerName   String
  reviewerEmail  String
  reviewerTitle  String?
  reviewerSocial String?
  reviewerAvatar String?
  isApproved     Boolean         @default(false)
  isArchived     Boolean         @default(false)
  isPinned       Boolean         @default(false)
  sentiment      Sentiment?
  importedFrom   ImportedFrom?
  externalLink   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  spaceId        String
  space          Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  collectionId   String?
  collection     Collection?     @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  translations   AITranslation[]
  aiSummary      AISummary?
  aiScore        AIScore?
  aiTags         AITags?
}

model Reward {
  id           String   @id @default(uuid())
  discountCode String
  message      String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  spaceId      String   @unique
  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Campaign {
  id         String   @id @default(uuid())
  subject    String
  emailBody  String
  recipients String[]
  sentCount  Int      @default(0)
  spaceId    String
  space      Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  spaceId   String
  widgetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([spaceId])
  @@index([widgetId])
}

model Widget {
  id        String   @id @default(uuid())
  spaceId   String
  name      String
  layout    String   // CAROUSEL, MASONRY, SINGLE, POPUP, FLOATING, WALL
  theme     String   // LIGHT, DARK, CUSTOM
  settings  Json     // styling config, filters, max testimonials
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model StaticPage {
  slug      String   @id
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model Collection {
  id              String                 @id @default(uuid())
  spaceId         String
  name            String
  slug            String                 @unique
  headline        String
  subheadline     String
  logoUrl         String?
  thankYouMessage String
  redirectUrl     String?
  customDomain    String?
  status          String                 @default("ACTIVE") // ACTIVE, ARCHIVED, DRAFT
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  space           Space                  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  testimonials    Testimonial[]
  theme           CollectionTheme?
  questions       CollectionQuestion[]
  views           CollectionView[]
  submissions     CollectionSubmission[]
  shares          CollectionShare[]

  @@index([spaceId])
}

model CollectionTheme {
  id              String     @id @default(uuid())
  collectionId    String     @unique
  primaryColor    String     @default("#10B981")
  textColor       String     @default("#E4E4E7")
  backgroundColor String     @default("#09090B")
  borderRadius    String     @default("8px")
  shadow          String     @default("md")
  spacing         Int        @default(16)
  fontFamily      String     @default("Outfit")
  darkMode        Boolean    @default(true)
  customCss       String?
  removeBranding  Boolean    @default(false)

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionQuestion {
  id           String     @id @default(uuid())
  collectionId String
  label        String
  type         String     // SHORT_ANSWER, PARAGRAPH, DROPDOWN, CHECKBOX, RADIO, RATING, DATE
  options      String[]   // JSON array or string values
  required     Boolean    @default(false)
  placeholder  String?
  order        Int        @default(0)

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model CollectionView {
  id           String     @id @default(uuid())
  collectionId String
  visitorId    String
  ipAddress    String?
  country      String?
  city         String?
  device       String?
  browser      String?
  os           String?
  referrer     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  createdAt    DateTime   @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model CollectionSubmission {
  id                String     @id @default(uuid())
  collectionId      String
  startedAt         DateTime
  completedAt       DateTime?
  testimonialId     String?
  consentGiven      Boolean    @default(false)
  consentTimestamp  DateTime?
  ipAddress         String?
  browser           String?
  country           String?
  isVerifiedEmail   Boolean    @default(false)
  verificationToken String?

  collection        Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model CollectionShare {
  id           String     @id @default(uuid())
  collectionId String
  platform     String     // TWITTER, FACEBOOK, LINKEDIN, COPY
  createdAt    DateTime   @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model ShowcaseSettings {
  id              String   @id @default(uuid())
  spaceId         String   @unique
  headline        String   @default("Our Wall of Love")
  subheadline     String   @default("See what our customers say about us.")
  ctaText         String   @default("Leave a Review")
  ctaUrl          String   @default("")
  logoUrl         String?
  coverImageUrl   String?
  layout          String   @default("MASONRY") // CLASSIC, MODERN, MASONRY, CAROUSEL, MINIMAL
  theme           String   @default("DARK")    // LIGHT, DARK, GLASSMORPHISM, GRADIENT
  customCss       String?
  showBranding    Boolean  @default(true)
  metaTitle       String   @default("Customer Reviews & Testimonials")
  metaDescription String   @default("Check out our customer testimonials showcasing real reviews and comments.")
  status          String   @default("ACTIVE")  // ACTIVE, DRAFT
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  space           Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model ShowcaseView {
  id           String   @id @default(uuid())
  spaceId      String
  visitorId    String
  ipAddress    String?
  country      String?
  device       String?
  browser      String?
  os           String?
  referrer     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  createdAt    DateTime @default(now())

  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model ShowcaseShare {
  id            String   @id @default(uuid())
  spaceId       String
  platform      String   // TWITTER, LINKEDIN, FACEBOOK, EMAIL, COPY
  testimonialId String?
  createdAt     DateTime @default(now())

  space         Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model Visitor {
  id        String   @id @default(uuid())
  spaceId   String
  visitorId String   @unique // unique tracking id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  sessions  VisitorSession[]
  conversions Conversion[]
  revenueEvents RevenueEvent[]

  @@index([spaceId])
}

model VisitorSession {
  id           String   @id @default(uuid())
  visitorId    String
  device       String   @default("Desktop")
  browser      String   @default("Other")
  os           String   @default("Other")
  country      String   @default("USA")
  city         String   @default("Unknown")
  referrer     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  startedAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  visitor      Visitor  @relation(fields: [visitorId], references: [visitorId], onDelete: Cascade)

  @@index([visitorId])
}

model Goal {
  id          String   @id @default(uuid())
  spaceId     String
  name        String
  description String?
  triggerType String   // CLICK, VIEW, CUSTOM
  category    String   // SIGNUP, PURCHASE, LEAD, CUSTOM
  value       Float    @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  conversions Conversion[]

  @@index([spaceId])
}

model Conversion {
  id          String   @id @default(uuid())
  spaceId     String
  visitorId   String
  goalId      String
  value       Float    @default(0.0)
  createdAt   DateTime @default(now())

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  visitor     Visitor  @relation(fields: [visitorId], references: [visitorId], onDelete: Cascade)
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([visitorId])
  @@index([goalId])
}

model RevenueEvent {
  id          String   @id @default(uuid())
  spaceId     String
  visitorId   String
  amount      Float
  currency    String   @default("USD")
  source      String?  // WIDGET, COLLECTION, SHOWCASE
  sourceId    String?  // widgetId or collectionId
  createdAt   DateTime @default(now())

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  visitor     Visitor  @relation(fields: [visitorId], references: [visitorId], onDelete: Cascade)

  @@index([spaceId])
  @@index([visitorId])
}

model HeatmapEvent {
  id        String   @id @default(uuid())
  spaceId   String
  targetId  String   // widgetId or collectionId
  type      String   // CLICK, SCROLL
  x         Float
  y         Float
  device    String   @default("Desktop")
  createdAt DateTime @default(now())

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model Report {
  id         String   @id @default(uuid())
  spaceId    String
  name       String
  range      String   // DAILY, WEEKLY, MONTHLY, YEARLY
  format     String   // CSV, EXCEL, PDF
  status     String   @default("READY")
  fileUrl    String?
  createdAt  DateTime @default(now())

  space      Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model AIUsage {
  id        String   @id @default(uuid())
  spaceId   String   @unique
  credits   Int      @default(0) // total credits used
  limit     Int      @default(10) // monthly limit
  updatedAt DateTime @updatedAt

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model AIHistory {
  id          String   @id @default(uuid())
  spaceId     String
  feature     String   // REWRITE, TRANSLATE, SOCIAL, SUMMARY, INSIGHTS
  creditsUsed Int      @default(1)
  inputLength Int      @default(0)
  createdAt   DateTime @default(now())

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model AIJob {
  id         String   @id @default(uuid())
  spaceId    String
  task       String
  status     String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  result     String?  // JSON response or path
  createdAt  DateTime @default(now())

  space      Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model AITranslation {
  id            String   @id @default(uuid())
  testimonialId String
  locale        String   // EN, ES, FR, DE, IT, PT, HI, JA, ZH, KO, AR
  translatedText String
  createdAt     DateTime @default(now())

  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)

  @@index([testimonialId])
}

model AISummary {
  id            String   @id @default(uuid())
  testimonialId String   @unique
  oneLiner      String
  twoLiner      String
  executive     String
  bulletPoints  String
  painPoints    String
  outcomes      String
  benefits      String
  createdAt     DateTime @default(now())

  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
}

model AIScore {
  id            String   @id @default(uuid())
  testimonialId String   @unique
  qualityScore  Int      @default(0)
  credibility   Int      @default(0)
  specificity   Int      @default(0)
  storytelling  Int      @default(0)
  suggestions   String
  createdAt     DateTime @default(now())

  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
}

model AITags {
  id            String   @id @default(uuid())
  testimonialId String   @unique
  tagsList      String   // Comma separated tags
  createdAt     DateTime @default(now())

  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
}

model AIInsight {
  id           String   @id @default(uuid())
  spaceId      String
  bestReviewId String?
  insightsText String
  personaMatch String
  missingTags  String
  createdAt    DateTime @default(now())

  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model IntegrationConnection {
  id          String   @id @default(uuid())
  spaceId     String
  appId       String   // SLACK, NOTION, HUBSPOT, MAILCHIMP
  status      String   @default("CONNECTED") // CONNECTED, DISCONNECTED
  config      String?  // JSON configuration details (webhookUrl, listId)
  accessToken String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model ApiKey {
  id        String   @id @default(uuid())
  spaceId   String
  name      String
  prefix    String   // pf_live_...
  key       String   // Hashed key
  scopes    String   // Comma separated list of permissions
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model WebhookSubscription {
  id           String   @id @default(uuid())
  spaceId      String
  targetUrl    String
  events       String   // Comma separated list of topics
  secret       String   // signature secret
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt    DateTime @default(now())

  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  logs         WebhookLog[]

  @@index([spaceId])
}

model WebhookLog {
  id             String   @id @default(uuid())
  subscriptionId String
  event          String
  statusCode     Int
  payload        String
  duration       Int      // execution latency in ms
  createdAt      DateTime @default(now())

  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model ApiLog {
  id           String   @id @default(uuid())
  spaceId      String
  endpoint     String
  method       String
  statusCode   Int
  ipAddress    String?
  duration     Int      // latency in ms
  createdAt    DateTime @default(now())

  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model WhiteLabelConfig {
  id             String   @id @default(uuid())
  spaceId        String   @unique
  brandName      String   @default("My Brand")
  logoUrl        String?
  darkLogoUrl    String?
  faviconUrl     String?
  primaryColor   String   @default("#10B981") // Emerald default
  secondaryColor String   @default("#8B5CF6") // Purple default
  accentColor    String   @default("#06B6D4") // Cyan default
  customCss      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  space          Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model SmtpConfig {
  id          String   @id @default(uuid())
  spaceId     String   @unique
  host        String
  port        Int      @default(587)
  username    String
  password    String   // Encrypted
  senderName  String
  senderEmail String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spaces      Space[]
  teams       Team[]
  roles       CustomRole[]
  sso         SsoConfig?
  ipPolicies  IpPolicy[]
}

model Team {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CustomRole {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  permissions    String   // Comma separated granular permission strings
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model IpPolicy {
  id             String   @id @default(uuid())
  organizationId String
  cidr           String   // e.g. 192.168.1.0/24
  type           String   @default("WHITELIST") // WHITELIST, BLACKLIST
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SsoConfig {
  id             String   @id @default(uuid())
  organizationId String   @unique
  provider       String   // OKTA, AUTH0, GOOGLE_WORKSPACE
  entryPoint     String
  issuer         String
  status         String   @default("ACTIVE") // ACTIVE, DISABLED
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model InAppNotification {
  id          String   @id @default(uuid())
  spaceId     String
  title       String
  description String
  category    String   // TESTIMONIAL, SYSTEM, ANALYTICS
  status      String   @default("UNREAD") // UNREAD, READ, ARCHIVED
  createdAt   DateTime @default(now())

  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}
