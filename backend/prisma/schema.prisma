datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BillingTier {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum TestimonialType {
  TEXT
  VIDEO
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ImportedFrom {
  TWITTER
  GOOGLE
  PRODUCTHUNT
}

enum SpaceRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String
  name                 String
  tier                 BillingTier           @default(FREE)
  aiCreditsUsed        Int                   @default(0)
  isVerified           Boolean               @default(false)
  status               String                @default("ACTIVE") // ACTIVE, DISABLED
  provider             String                @default("EMAIL") // EMAIL, GOOGLE, GITHUB
  hasPassword          Boolean               @default(true)
  failedLoginAttempts  Int                   @default(0)
  lockoutUntil         DateTime?
  lastLogin            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  spaces               Space[]
  memberships          SpaceMember[]
  invitations          WorkspaceInvitation[] @relation("invitedBy")
  passwordResetTokens  PasswordResetToken[]
  otpTokens            OTPToken[]
  emailChangeRequest   EmailChangeRequest?
  sessions             Session[]
  refreshTokens        RefreshToken[]
  oauthAccounts        OAuthAccount[]
  loginHistories       LoginHistory[]
  auditLogs            AuditLog[]
  passwordHistories    PasswordHistory[]
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Space {
  id               String                @id @default(uuid())
  name             String
  slug             String                @unique
  headerTitle      String
  customMessage    String
  logoUrl          String?
  collectVideo     Boolean               @default(true)
  collectText      Boolean               @default(true)
  theme            String                @default("light")
  showBranding     Boolean               @default(true)
  customDomain     String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  testimonials     Testimonial[]
  campaigns        Campaign[]
  webhooks         Webhook[]
  reward           Reward?
  members          SpaceMember[]
  invitations      WorkspaceInvitation[]
  widgets          Widget[]
  collections      Collection[]
}

model SpaceMember {
  id        String    @id @default(uuid())
  spaceId   String
  userId    String
  role      SpaceRole @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([spaceId, userId])
}

model WorkspaceInvitation {
  id         String    @id @default(uuid())
  spaceId    String
  email      String
  role       SpaceRole @default(MEMBER)
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  space      Space     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  inviter    User      @relation("invitedBy", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([spaceId, email])
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTPToken {
  id        String   @id @default(uuid())
  userId    String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailChangeRequest {
  id          String   @id @default(uuid())
  userId      String   @unique
  oldEmail    String
  newEmail    String
  oldToken    String   @unique
  newToken    String   @unique
  oldVerified Boolean  @default(false)
  newVerified Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String         @id @default(uuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent    String?
  ipAddress    String?
  deviceType   String?        @default("Desktop")
  isValid      Boolean        @default(true)
  createdAt    DateTime       @default(now())
  expiresAt    DateTime
  lastActivity DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

model OAuthAccount {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String   // "GOOGLE", "GITHUB"
  providerUserId String   // unique identifier from google/github
  metadata       Json?
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  browser    String?
  os         String?
  device     String?
  status     String   // "SUCCESS", "FAIL_PASSWORD", "FAIL_LOCKED", etc.
  createdAt  DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id             String          @id @default(uuid())
  type           TestimonialType
  textContent    String?
  videoUrl       String?
  rating         Int             @default(5)
  reviewerName   String
  reviewerEmail  String
  reviewerTitle  String?
  reviewerSocial String?
  reviewerAvatar String?
  isApproved     Boolean         @default(false)
  isArchived     Boolean         @default(false)
  isPinned       Boolean         @default(false)
  sentiment      Sentiment?
  importedFrom   ImportedFrom?
  externalLink   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  spaceId        String
  space          Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  collectionId   String?
  collection     Collection?     @relation(fields: [collectionId], references: [id], onDelete: SetNull)
}

model Reward {
  id           String   @id @default(uuid())
  discountCode String
  message      String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  spaceId      String   @unique
  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Campaign {
  id         String   @id @default(uuid())
  subject    String
  emailBody  String
  recipients String[]
  sentCount  Int      @default(0)
  spaceId    String
  space      Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Webhook {
  id        String   @id @default(uuid())
  url       String
  isActive  Boolean  @default(true)
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  spaceId   String
  widgetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([spaceId])
  @@index([widgetId])
}

model Widget {
  id        String   @id @default(uuid())
  spaceId   String
  name      String
  layout    String   // CAROUSEL, MASONRY, SINGLE, POPUP, FLOATING, WALL
  theme     String   // LIGHT, DARK, CUSTOM
  settings  Json     // styling config, filters, max testimonials
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model StaticPage {
  slug      String   @id
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model Collection {
  id              String                 @id @default(uuid())
  spaceId         String
  name            String
  slug            String                 @unique
  headline        String
  subheadline     String
  logoUrl         String?
  thankYouMessage String
  redirectUrl     String?
  customDomain    String?
  status          String                 @default("ACTIVE") // ACTIVE, ARCHIVED, DRAFT
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  space           Space                  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  testimonials    Testimonial[]
  theme           CollectionTheme?
  questions       CollectionQuestion[]
  views           CollectionView[]
  submissions     CollectionSubmission[]
  shares          CollectionShare[]

  @@index([spaceId])
}

model CollectionTheme {
  id              String     @id @default(uuid())
  collectionId    String     @unique
  primaryColor    String     @default("#10B981")
  textColor       String     @default("#E4E4E7")
  backgroundColor String     @default("#09090B")
  borderRadius    String     @default("8px")
  shadow          String     @default("md")
  spacing         Int        @default(16)
  fontFamily      String     @default("Outfit")
  darkMode        Boolean    @default(true)
  customCss       String?
  removeBranding  Boolean    @default(false)

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionQuestion {
  id           String     @id @default(uuid())
  collectionId String
  label        String
  type         String     // SHORT_ANSWER, PARAGRAPH, DROPDOWN, CHECKBOX, RADIO, RATING, DATE
  options      String[]   // JSON array or string values
  required     Boolean    @default(false)
  placeholder  String?
  order        Int        @default(0)

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model CollectionView {
  id           String     @id @default(uuid())
  collectionId String
  visitorId    String
  ipAddress    String?
  country      String?
  city         String?
  device       String?
  browser      String?
  os           String?
  referrer     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  createdAt    DateTime   @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model CollectionSubmission {
  id                String     @id @default(uuid())
  collectionId      String
  startedAt         DateTime
  completedAt       DateTime?
  testimonialId     String?
  consentGiven      Boolean    @default(false)
  consentTimestamp  DateTime?
  ipAddress         String?
  browser           String?
  country           String?
  isVerifiedEmail   Boolean    @default(false)
  verificationToken String?

  collection        Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

model CollectionShare {
  id           String     @id @default(uuid())
  collectionId String
  platform     String     // TWITTER, FACEBOOK, LINKEDIN, COPY
  createdAt    DateTime   @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}
